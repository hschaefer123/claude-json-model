<mvc:View xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc">
    <IconTabBar class="sapUiResponsiveContentPadding" expandable="false" 
		expanded="{device>/isNoPhone}" stretchContentHeight="true">
		<items> 
			<IconTabFilter text="{i18n>ClaudeJSONodel}" key="claudeai">
				<Image class="uHeroImage" src="../mime/ClaudeJSONModel.webp" 
                    width="100%" height="100%" 
                    mode="Background" backgroundSize="contain" backgroundPosition="center"/>
			</IconTabFilter>
			<IconTabFilter text="{i18n>Why}" key="question">
                <Image class="uHeroImage" src="../mime/fetch-vs-claudejsonmodel.webp" 
                    width="100%" height="100%" 
                    mode="Background" backgroundSize="contain" backgroundPosition="center"/>
			</IconTabFilter>
			<IconTabFilter text="{i18n>Features}" key="features">
				<Image src="../mime/ClaudeJSONModel-Features.webp" 
                    width="100%" height="100%" 
                    mode="Background" backgroundSize="contain" backgroundPosition="center"/>
			</IconTabFilter>
		</items>
	</IconTabBar>    
</mvc:View>
